# Firebase Configuration
# Dapatkan dari: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app config
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Cloudinary Configuration
# Dapatkan dari: https://console.cloudinary.com/
# Dashboard > Account Details
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
# Settings > Upload > Upload presets > Add upload preset (unsigned)
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
